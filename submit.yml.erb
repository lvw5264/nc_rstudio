batch_connect:
  template: "basic"
  conn_params:
    - csrftoken

script:
  native: [
            "-N", "1",
            "-c", "<%= nc_cpus.blank?  ? 1 : nc_cpus.to_i %>",
            <%- if not nc_gpus.blank? -%>
                "-G", "<%= nc_gpus.to_i %>",
            <%- end -%>
            <%- if not nc_mem.blank? -%>
                "--mem", "<%= nc_mem.to_i %>G",
            <%- end -%>
            <%- if not nc_features.blank? -%>
                "--constraint", "<%= nc_features %>"
            <%- end -%>
          ]
