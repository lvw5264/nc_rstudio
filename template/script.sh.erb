#!/usr/bin/env bash

# load modules
module reset
# make sure rserver module exists and contains Posit provided RStudio paths
module load <%= context.auto_modules_rserver %>
module load <%= context.auto_modules_r %>
<%- unless context.sh_modules.blank? -%>
module load <%= context.sh_modules %>
<%- end -%>

# create server configuration
# PWD refers to job folder
export RSTUDIO_CONFIG_DIR=$PWD      # system config, in a path readable by OOD job output
# create /tmp directory for storing 4KB of sockets. note this directory will be set chmod 777 readable by anyone by rstudio server
export RSTUDIO_DATA_DIR="$(mktemp -d)/rserver"  # per-session sockets
export RSTUDIO_AUTH="$PWD/bin/auth"

### Alternative to password auth if your webapp supports it
## https://github.com/tefarley/ood-rstudio/blob/main/template/script.sh.erb
#export RSTUDIO_COOKIE_FILE="${RSTUDIO_DATA_DIR}/secure-cookie-key"
#python3 -c 'from uuid import uuid4; print(uuid4())' > "${RSTUDIO_COOKIE_FILE}"
#chmod 0600 "${RSTUDIO_COOKIE_FILE}"
## Then make sure to configure rserver.con


_workspace_dir=<%= context.sh_workspace.blank? ? "$HOME" : context.sh_workspace %>

cat <<-EOF > $RSTUDIO_CONFIG_DIR/rserver.conf
server-user=$USER
www-port=$port
# if you get any login problems with csrf, set auth-none=1 temporarily to disable csrf-token and password auth
auth-none=0
auth-pam-helper-path=$RSTUDIO_AUTH
auth-encrypt-password=0
auth-timeout-minutes=0
database-config-file=$RSTUDIO_CONFIG_DIR/database.conf
# use /tmp to store rstudio sockets..       
# Also beware that this directory will be set chmod 777
server-data-dir=$RSTUDIO_DATA_DIR
server-app-armor-enabled=0
EOF

cat <<-EOF > $RSTUDIO_CONFIG_DIR/rsession.conf
session-timeout-minutes=0
session-timeout-suspend=0
session-save-action-default=no
session-quit-child-processes-on-exit=1
r-restore-workspace=0
session-default-working-dir=$_workspace_dir
EOF
cat <<-EOF > $RSTUDIO_CONFIG_DIR/logging.conf
[*]
log-level=info
logger-type=file
log-dir=$RSTUDIO_CONFIG_DIR/sessions
EOF
cat <<-EOF > $RSTUDIO_CONFIG_DIR/database.conf
provider=sqlite
directory=$RSTUDIO_CONFIG_DIR
pool-size=$SLURM_CPUS_ON_NODE
EOF
mkdir $RSTUDIO_CONFIG_DIR/sessions

# start server
rserver 2>&1


